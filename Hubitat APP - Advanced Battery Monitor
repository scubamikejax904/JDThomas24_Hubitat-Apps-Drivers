definition(
    name: "AdvancedBatteryMonitor",
    namespace: "custom",
    author: "Jdthomas24",
    description: "Advanced battery monitoring with alerts, reporting, and battery tracking.",
    category: "Convenience",
    iconUrl: "https://s3.amazonaws.com/smartapp-icons/Convenience/Cat-Convenience.png",
    iconX2Url: "https://s3.amazonaws.com/smartapp-icons/Convenience/Cat-Convenience@2x.png"
)

preferences {
    page(name: "configPage")
}

def configPage() {

    dynamicPage(name: "configPage", title: "Advanced Battery Monitor", install: true, uninstall: true) {

        section("Battery Devices") {

            input "autoDiscover",
                    "bool",
                    title: "Automatically discover battery devices",
                    defaultValue: true

            input "devices",
                    "capability.battery",
                    title: "Manual device selection (optional)",
                    multiple: true,
                    required: false
        }

        section("Battery Thresholds") {

            input "lowLevel",
                    "number",
                    title: "Low Battery Threshold (%)",
                    defaultValue: 25

            input "criticalLevel",
                    "number",
                    title: "Critical Battery Threshold (%)",
                    defaultValue: 10
        }

        section("Monitoring Frequency") {

            input "checkInterval",
                    "enum",
                    title: "Battery scan frequency",
                    options: [
                            "5":"Every 15 minutes",
                            "15":"Every 30 minutes",
                            "30":"Every 90 minutes",
                            "120":"2 Hours",
                            "480":"8 Hours"
                        
                    ],
                    defaultValue: "60"
        }

        section("Notifications") {

            input "enablePush",
                    "bool",
                    title: "Enable Notifications",
                    defaultValue: true

            input "notifyDevices",
                    "capability.notification",
                    title: "Notification Devices",
                    multiple: true,
                    required: false
        }

        section("Battery Summary Reports") {

            input "dailySummary",
                    "bool",
                    title: "Enable Summary Reports",
                    defaultValue: true

            input "summaryFrequency",
                    "enum",
                    title: "Summary Frequency",
                    options: [
                            "1":"Every Day",
                            "2":"Every Other Day",
                            "3":"Every 3 Days",
                            "7":"Weekly"
                    ],
                    defaultValue: "1"

            input "summaryTime",
                    "time",
                    title: "Summary Time",
                    required: false
        }

        section("Options") {
            label title: "App Name", required: false
        }
    }
}

def installed() {
    initialize()
}

def updated() {
    unsubscribe()
    unschedule()
    initialize()
}

def initialize() {

    log.debug "Advanced Battery Monitor Initialized"

    state.lastAlert = [:]
    state.batteryHistory = [:]

    def batteryDevices = getBatteryDevices()

    subscribe(batteryDevices, "battery", batteryEvent)

    if(checkInterval == "15") runEvery15Minutes(scanBatteries)
    if(checkInterval == "30") runEvery30Minutes(scanBatteries)
    if(checkInterval == "90") runEvery90Minutes(scanBatteries)
    if(checkInterval == "120") runEvery2Hour(scanBatteries)
    if(checkInterval == "480") runEvery8Hours(scanBatteries)

    if(dailySummary && summaryTime) {
        schedule(summaryTime, summaryScheduler)
    }
}

def getBatteryDevices() {

    if(autoDiscover) {
        return location.devices.findAll { it.hasCapability("Battery") }
    }

    return devices
}

def batteryEvent(evt) {

    def device = evt.device
    def level = evt.value

    if(level == null) return

    level = level.toInteger()

    trackBattery(device, level)
    evaluateBattery(device, level)
}

def scanBatteries() {

    def batteryDevices = getBatteryDevices()

    batteryDevices.each {

        try {

            def level = it.currentValue("battery")

            if(level != null) {

                level = level.toInteger()

                trackBattery(it, level)
                evaluateBattery(it, level)
            }

        } catch(e) {

            log.warn "Battery read error for ${it.displayName}"
        }
    }
}

def trackBattery(device, level) {

    if(!state.batteryHistory[device.id]) {

        state.batteryHistory[device.id] = [
                lastLevel: level,
                lastDate: new Date().time
        ]

        return
    }

    def previous = state.batteryHistory[device.id]

    if(level != previous.lastLevel) {

        previous.lastLevel = level
        previous.lastDate = new Date().time
    }
}

def evaluateBattery(device, level) {

    if(state.lastAlert[device.id] == level) return

    if(level <= criticalLevel) {

        notify("CRITICAL: ${device.displayName} battery is ${level}%")
        state.lastAlert[device.id] = level
        return
    }

    if(level <= lowLevel) {

        notify("LOW: ${device.displayName} battery is ${level}%")
        state.lastAlert[device.id] = level
    }
}

def notify(msg) {

    log.debug msg

    if(!enablePush) return

    if(notifyDevices) {

        notifyDevices.each {
            it.deviceNotification(msg)
        }

    } else {

        sendPush(msg)
    }
}

def summaryScheduler() {

    if(!state.lastSummaryDay) {
        state.lastSummaryDay = 0
    }

    def today = new Date().format("D", location.timeZone).toInteger()
    def interval = summaryFrequency.toInteger()

    if((today - state.lastSummaryDay) >= interval) {

        sendBatteryReport()
        state.lastSummaryDay = today
    }
}

def sendBatteryReport() {

    def batteryDevices = getBatteryDevices()
    def hubName = location.hubs[0].name

    def critical = []
    def low = []
    def good = []

    batteryDevices.each {

        try {

            def level = it.currentValue("battery")

            if(level == null) return

            level = level.toInteger()

            if(level <= criticalLevel) {
                critical << [level, it.displayName]
            }
            else if(level <= lowLevel) {
                low << [level, it.displayName]
            }
            else {
                good << [level, it.displayName]
            }

        } catch(e) {
            log.warn "Battery report error for ${it.displayName}"
        }
    }

    critical.sort{ it[0] }
    low.sort{ it[0] }
    good.sort{ it[0] }

    def msg = []
    msg << "Battery Report for ${hubName}\r\n"

    if(critical) {
        msg << "\r\nCRITICAL"
        critical.each { msg << "${it[0]}%  ${it[1]}" }
    }

    if(low) {
        msg << "\r\nLOW"
        low.each { msg << "${it[0]}%  ${it[1]}" }
    }

    if(good) {
        msg << "\r\nGOOD"
        good.each { msg << "${it[0]}%  ${it[1]}" }
    }

    notify(msg.join("\r\n"))
}
