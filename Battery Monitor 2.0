
definition(
    name: "Battery Monitor 2.0",
    namespace: "custom",
    author: "Jdthomas24",
    description: "Advanced battery monitoring with categorized alerts and reports.",
    category: "Convenience",
    iconUrl: "",
    iconX2Url: ""
)

preferences {
    page(name: "configPage")
}

def configPage() {
    dynamicPage(name: "configPage", title: "Battery Monitor 2.0", install: true, uninstall: true) {

        section("Battery Devices") {
            input "autoDiscover", "bool",
                title: "Automatically discover battery devices",
                defaultValue: true

            input "devices", "capability.battery",
                title: "Manual device selection (optional)",
                multiple: true,
                required: false
        }

        section("Battery Thresholds") {
            input "criticalLevel", "number",
                title: "Critical Battery Threshold (%)",
                defaultValue: 25
        }

        section("Scan Frequency") {
            input "checkInterval", "enum",
                title: "Battery Scan Frequency",
                options: [
                    "15":"Every 15 minutes",
                    "30":"Every 30 minutes",
                    "60":"Every hour",
                    "180":"Every 3 hours",
                    "480":"Every 8 hours"
                ],
                defaultValue: "60"
        }

        section("Notifications") {
            input "enablePush", "bool",
                title: "Enable Notifications",
                defaultValue: true

            input "notifyDevices", "capability.notification",
                title: "Notification Devices",
                multiple: true,
                required: false
        }

        section("Battery Reports") {
            input "dailySummary", "bool",
                title: "Enable Battery Reports",
                defaultValue: true

            input "summaryFrequency", "enum",
                title: "Report Frequency",
                options: [
                    "1":"Every Day",
                    "2":"Every Other Day",
                    "3":"Every 3 Days",
                    "7":"Weekly"
                ],
                defaultValue: "1"

            input "summaryTime", "time",
                title: "Report Time"
        }

        section("Options") {
            label title: "App Name", required: false
        }
    }
}

def installed() {
    initialize()
}

def updated() {
    log.info "Battery Monitor 2.0 updated. Rescheduling tasks."
    unsubscribe()
    unschedule()
    initialize()
}

def initialize() {
    log.info "Battery Monitor 2.0 Initialized"

    state.lastAlert = [:]
    state.summaryRun = false

    def batteryDevices = getBatteryDevices()
    if(batteryDevices) {
        subscribe(batteryDevices, "battery", batteryEvent)
    }

    scheduleBatteryScan()

    if(dailySummary && summaryTime) {
        try {
            schedule(summaryTime, summaryScheduler)
            log.info "Battery summary scheduled at ${summaryTime}"
        } catch(e) {
            log.error "Failed to schedule summary: ${e}"
        }
    }
}

def scheduleBatteryScan() {
    switch(checkInterval) {
        case "15":
            runEvery15Minutes(scanBatteries)
            break
        case "30":
            runEvery30Minutes(scanBatteries)
            break
        case "60":
            runEvery1Hour(scanBatteries)
            break
        case "180":
            runEvery3Hours(scanBatteries)
            break
        case "480":
            schedule("0 0 */8 ? * *", scanBatteries)
            break
    }
}

def getBatteryDevices() {
    def devs = []
    if(autoDiscover) {
        devs = location.allDevices.findAll { it.hasCapability("Battery") }
    }
    if(devices) {
        devs += devices
    }
    return devs.unique { it.id }
}

def batteryEvent(evt) {
    def level = evt.value?.toInteger()
    if(level == null) return
    evaluateBattery(evt.device, level)
}

def scanBatteries() {
    log.debug "Scanning battery devices"
    getBatteryDevices().each { device ->
        try {
            def level = device.currentValue("battery")
            if(level != null) {
                evaluateBattery(device, level.toInteger())
            }
        } catch(e) {
            log.warn "Battery read error for ${device.displayName}"
        }
    }
}

def evaluateBattery(device, level) {
    // Skip immediate alerts if summary report is running
    if(state.summaryRun) return

    if(state.lastAlert[device.id] == level) return

    if(level <= criticalLevel) {
        notify("CRITICAL: ${device.displayName} battery is ${level}%")
        state.lastAlert[device.id] = level
        return
    }

    if(level > criticalLevel && level <= 70) {
        notify("GOOD: ${device.displayName} battery is ${level}%")
        state.lastAlert[device.id] = level
        return
    }

    if(level > 70 && level < 100) {
        notify("HIGH CHARGE: ${device.displayName} battery is ${level}%")
        state.lastAlert[device.id] = level
        return
    }

    if(level == 100) {
        notify("FULL CHARGE: ${device.displayName} battery is ${level}%")
        state.lastAlert[device.id] = level
    }
}

def notify(msg) {
    log.info msg
    if(!enablePush) return

    if(notifyDevices) {
        notifyDevices.each {
            it.deviceNotification(msg)
        }
    } else {
        sendPushMessage(msg)
    }
}

def summaryScheduler() {
    log.debug "Running scheduled battery summary"
    state.summaryRun = true
    sendBatteryReport()
    state.lastSummary = now()
    state.summaryRun = false
}

def sendBatteryReport() {
    def devs = getBatteryDevices()
    if(!devs || devs.size() == 0) {
        notify("Battery Report: No battery devices found")
        return
    }

    def critical = []
    def good = []
    def high = []
    def full = []

    devs.each { d ->
        try {
            def level = d.currentValue("battery")
            if(level == null) return
            level = level.toInteger()
            if(level <= criticalLevel) critical << [name: d.displayName, level: level]
            else if(level <= 70) good << [name: d.displayName, level: level]
            else if(level < 100) high << [name: d.displayName, level: level]
            else full << [name: d.displayName, level: level]
        } catch(e) {
            log.warn "Battery report error for ${d.displayName}"
        }
    }

    critical = critical.sort { it.level }
    good = good.sort { it.level }
    high = high.sort { it.level }
    full = full.sort { it.name }

    def msg = []
    msg << "Battery Report (${devs.size()} Devices)"

    if(critical) {
        msg << ""
        msg << "CRITICAL BATTERIES (≤${criticalLevel}%)"
        critical.each { msg << "${it.level}% - ${it.name}" }
    }

    if(good) {
        msg << ""
        msg << "GOOD BATTERIES (26–70%)"
        good.each { msg << "${it.level}% - ${it.name}" }
    }

    if(high) {
        msg << ""
        msg << "HIGH CHARGE BATTERIES (71–99%)"
        high.each { msg << "${it.level}% - ${it.name}" }
    }

    if(full) {
        msg << ""
        msg << "FULL CHARGE (100%)"
        full.each { msg << "${it.level}% - ${it.name}" }
    }

    notify(msg.join("\n"))
}

